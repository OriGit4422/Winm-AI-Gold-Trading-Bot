# ============================================================
# WINM AI Gold Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
# AI Studio automatically injects GEMINI_API_KEY at runtime.

# --- AI ---
# Required for Gemini AI features. Injected automatically by AI Studio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- App URL ---
# Injected automatically by AI Studio (Cloud Run service URL).
APP_URL="MY_APP_URL"

# ============================================================
# MARKET DATA — pick ONE provider for live prices
# ============================================================

# Option 1 (RECOMMENDED): Twelve Data — WebSocket real-time streaming
# Supports forex, commodities (XAU/USD, XAG/USD), crypto, stocks.
# Free tier: 800 API calls/day, 8 WebSocket instruments.
# Get a free key at: https://twelvedata.com/
TWELVE_DATA_API_KEY=""

# Option 2: Alpha Vantage — REST polling (1 symbol per 12s, free tier)
# Free tier: 25 requests/day (sufficient for slow polling of 8 symbols).
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=""

# If NEITHER key is set, the server falls back to a built-in price
# simulator (random walk). All other features remain functional.

# ============================================================
# NEWS FEED
# ============================================================
# Required for the Market Intelligence news panel.
# Get a free key at: https://newsapi.org/
VITE_NEWS_API_KEY=""

# ============================================================
# MT5 TERMINAL (optional — for live trade execution)
# ============================================================
# Store your MetaTrader 5 credentials here.
# The Config tab reads these as default form values.
# Live execution via MT5 requires MetaApi SDK (https://metaapi.cloud)
# or a local MT5 terminal bridge.
MT5_SERVER=""
MT5_LOGIN=""
MT5_PASSWORD=""
